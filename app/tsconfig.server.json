{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2020",
    "outDir": "dist/server",
    "rootDir": ".",
    "noEmit": false,
    "moduleResolution": "Node",
    "types": ["node"]
  },
  "include": ["server/**/*.ts", "data/**/*.ts", "controller/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
